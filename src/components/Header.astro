---
import { site } from '../config/site';
import Icon from './Icon.astro';
---
<header class="ps-header">
  <div class="ps-container ps-header__inner">
    <a class="ps-brand" href="/" aria-label={`${site.name} home`}>
      <svg class="ps-brand__mark" viewBox="0 0 60 40" fill="var(--ps-accent)" aria-hidden="true">
        <g transform="translate(2,0) scale(0.62)"><polygon points="12,1 14.5,8.5 22,8.5 16,13 18,21 12,16.5 6,21 8,13 2,8.5 9.5,8.5"/></g>
        <g transform="translate(23,0) scale(0.62)"><polygon points="12,1 14.5,8.5 22,8.5 16,13 18,21 12,16.5 6,21 8,13 2,8.5 9.5,8.5"/></g>
        <g transform="translate(44,0) scale(0.62)"><polygon points="12,1 14.5,8.5 22,8.5 16,13 18,21 12,16.5 6,21 8,13 2,8.5 9.5,8.5"/></g>
        <rect x="0" y="27" width="60" height="4.5"/>
        <rect x="0" y="34" width="60" height="4.5"/>
      </svg>
      <span>{site.name}</span>
    </a>

    <nav class="ps-nav" aria-label="Primary">
      <span class="ps-nav__links" style="display:contents">
        <a href="#about">About</a>
        <a href="#projects">Projects</a>
      </span>
      <button class="ps-theme-toggle" type="button" id="theme-toggle" aria-label="Toggle dark mode">
        <Icon name="sun" />
        <Icon name="moon" />
      </button>
    </nav>
  </div>
</header>
